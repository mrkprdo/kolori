  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean": "node scripts/clean-build.js",
    "clean:android": "node scripts/clean-android-build.js",
    "build:clean": "npm run clean && eas build",
    "build:android": "npm run clean && eas build --platform android",
